<joint name="Rigid 1" type="fixed">
  <origin xyz="0.0 0.0 0.05" rpy="0 0 0" />
  <parent link="base_link" />
  <child link="Base_1" />
</joint>

<joint name="Revolute 2" type="continuous">
  <origin xyz="-0.0 -0.012092 0.1625" rpy="0 0 0" />
  <parent link="Base_1" />
  <child link="Shoulder_1" />
  <axis xyz="0.0 0.0 1.0" />
</joint>

<joint name="Revolute 3" type="continuous">
  <origin xyz="-0.074 0.0 0.149" rpy="0 0 0" />
  <parent link="Shoulder_1" />
  <child link="Elbow_1" />
  <axis xyz="-1.0 0.0 -0.0" />
</joint>

<joint name="Revolute 4" type="continuous">
  <origin xyz="0.0 0.0 0.2" rpy="0 0 0" />
  <parent link="Elbow_1" />
  <child link="Elbow_2" />
  <axis xyz="1.0 -0.0 0.0" />
</joint>

<joint name="Revolute 5" type="continuous">
  <origin xyz="0.0 0.2 0.0" rpy="0 0 0" />
  <parent link="Elbow_2" />
  <child link="Wrist_1" />
  <axis xyz="-1.0 0.0 -0.0" />
</joint>

<joint name="Revolute 6" type="continuous">
  <origin xyz="-0.0725 0.0 0.0725" rpy="0 0 0" />
  <parent link="Wrist_1" />
  <child link="End_Effector_1" />
